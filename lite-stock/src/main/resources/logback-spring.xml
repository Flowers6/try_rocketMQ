    </appender>

    <logger name="com.chance.hell" level="DEBUG"/>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="FILE_INFO"/>
      <appender-ref ref="FILE_WARN"/>
      <appender-ref ref="FILE_ERROR"/>
      <appender-ref ref="logstash"/>
    </root>
  </springProfile>

